{
  "name": "cursor-bot",
  "version": "1.0.0",
  "description": "SuperMessenger bot powered by Cursor Agent SDK",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:supervised": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/watchdog.ps1",
    "start:tsx": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "feed": "tsx src/tggate-feed-demo.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.16",
    "dotenv": "^16.4.7",
    "node-forge": "^1.4.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/node-forge": "^1.3.14",
    "@types/ws": "^8.18.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
