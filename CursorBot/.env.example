# SuperMessenger Bot API
SUPRA_BASE_URL=https://your-server.example.com
SUPRA_BOT_LOGIN=cursor_bot
SUPRA_BOT_TOKEN=your-bot-api-token

# Cursor Agent SDK
CURSOR_API_KEY=cursor_...
# Модель по умолчанию для новых чатов: auto | pro | composer-2.5 | ...
CURSOR_DEFAULT_MODEL=auto
# Модель для пресета Pro (Premium)
CURSOR_PRO_MODEL=claude-opus-4-8
# Устаревший алиас для CURSOR_DEFAULT_MODEL
# CURSOR_MODEL=composer-2.5
# cloud | local
CURSOR_RUNTIME=cloud

# Cloud agent (when CURSOR_RUNTIME=cloud)
CURSOR_REPO_URL=https://github.com/your-org/your-repo
CURSOR_REPO_REF=main
# CURSOR_AUTO_CREATE_PR=false

# Local agent (when CURSOR_RUNTIME=local)
# Папки проектов задаются в data/bot-config.json (см. bot-config.example.json)
# CURSOR_CWD больше не используется — список проектов в JSON-конфиге
# BOT_CONFIG=./data/bot-config.json

# Поведение бота
# Макс. длина одного сообщения в мессенджере (разбивка длинных ответов)
SUPRA_MAX_MESSAGE_CHARS=8000
# Показывать индикатор «печатает» во время обработки запроса (sendActivity)
SUPRA_SEND_TYPING=true
# Живое сообщение с мыслями/действиями агента (edit + delete перед ответом).
# Можно включать вместе с SUPRA_SEND_TYPING.
SUPRA_SEND_THOUGHT_STATUS=true
# Минимальный интервал обновления живого сообщения (мс)
SUPRA_THOUGHT_UPDATE_MS=3500
# Макс. длина текста живого сообщения
SUPRA_THOUGHT_MAX_CHARS=600
# Файл состояния (lastInboxId, agentId по чатам)
STATE_FILE=./data/state.json

# Входящие файлы от пользователей (скачиваются в {project}/tmp/bot-inbox/)
# SUPRA_MAX_FILE_BYTES=104857600
