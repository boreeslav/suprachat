# DEPRECATED: use tmp/deploy/deploy.env (see tmp/deploy/deploy.env.example).
# This file is kept for reference only.

SM_DEPLOY_HOST=
SM_DEPLOY_USER=root
SM_DEPLOY_PASSWORD=
SM_DEPLOY_APP_PORT=8080
SM_DEPLOY_ADMIN_LOGIN=admin
SM_DEPLOY_ADMIN_PASSWORD=
# Optional. Leave empty if not used.
# HTTPS via nginx on the server (Let's Encrypt). Example:
SM_DEPLOY_PUBLIC_URL=https://xn--80aa8ccsc.xn--p1ai
# Optional client connection mode: https | http | auto (default).
#   https — secure: native WebCrypto, persistent encrypted store (IndexedDB), Service Worker
#   http  — legacy: node-forge polyfill, sessionStorage master password, no Service Worker
#   auto/empty — derived from SM_DEPLOY_PUBLIC_URL scheme, then browser isSecureContext
SM_DEPLOY_PROTOCOL=
