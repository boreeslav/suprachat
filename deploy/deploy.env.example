# DEPRECATED: use tmp/deploy/deploy.env (see tmp/deploy/deploy.env.example).
# This file is kept for reference only.

# Primary server (always deployed first)
SM_DEPLOY_HOST=
SM_DEPLOY_USER=root
SM_DEPLOY_PASSWORD=
SM_DEPLOY_HOSTKEY=
SM_DEPLOY_APP_PORT=8080
SM_DEPLOY_ADMIN_LOGIN=admin
SM_DEPLOY_ADMIN_PASSWORD=
SM_DEPLOY_PUBLIC_URL=https://messenger.example.com
# Optional. Public hostname for nginx/Let's Encrypt (defaults to host from SM_DEPLOY_PUBLIC_URL).
SM_DEPLOY_DOMAIN=messenger.example.com
SM_DEPLOY_PROTOCOL=

# Reserve server (deploy only after confirmation)
SM_DEPLOY_HOST_RESERVE=
SM_DEPLOY_USER_RESERVE=root
SM_DEPLOY_PASSWORD_RESERVE=
SM_DEPLOY_HOSTKEY_RESERVE=

# Deploy status messages in chat (optional fallback; CursorBot writes tmp/deploy/status-target.json):
# SM_DEPLOY_STATUS_BASE_URL=https://your-server.example.com
# SM_DEPLOY_STATUS_BOT_LOGIN=cursor_bot
# SM_DEPLOY_STATUS_BOT_TOKEN=your-bot-api-token
# SM_DEPLOY_STATUS_CHAT_ID=
# SM_DEPLOY_STATUS_USER_LOGIN=
